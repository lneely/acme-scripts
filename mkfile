install:V:
	cp git/G+ $HOME/bin/G+
	cp git/G++ $HOME/bin/G++
	cp git/G- $HOME/bin/G-
	cp git/G-- $HOME/bin/G--
	cp git/Gc $HOME/bin/Gc
	cp git/Gdif $HOME/bin/Gdif
	cp git/Gdn $HOME/bin/Gdn
	cp git/Gds $HOME/bin/Gds
	cp git/Gf $HOME/bin/Gf
	cp git/Gpat $HOME/bin/Gpat
	cp git/Gst $HOME/bin/Gst
	cp git/Gup $HOME/bin/Gup

clean:V:
	rm -f $HOME/bin/G+ $HOME/bin/G++ $HOME/bin/G- $HOME/bin/G-- $HOME/bin/Gc $HOME/bin/Gdif $HOME/bin/Gdn $HOME/bin/Gds $HOME/bin/Gf $HOME/bin/Gpat $HOME/bin/Gst $HOME/bin/Gup
